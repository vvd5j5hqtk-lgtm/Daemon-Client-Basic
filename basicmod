                    </div>

                    <div id="tab-stat" style="display: none;">
                        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 15px;">
                            <div class="daemon-stat-card"><span class="daemon-stat-label">Kill / Death Ratio</span><span class="daemon-stat-val" id="stat-kd">0.00</span></div>
                            <div class="daemon-stat-card"><span class="daemon-stat-label">Total Kills</span><span class="daemon-stat-val" id="stat-kills">0</span></div>
                            <div class="daemon-stat-card"><span class="daemon-stat-label">Highest Kill Streak</span><span class="daemon-stat-val" id="stat-streak">0</span></div>
                            <div class="daemon-stat-card"><span class="daemon-stat-label">Total Deaths</span><span class="daemon-stat-val" id="stat-deaths">0</span></div>
                            <div class="daemon-stat-card"><span class="daemon-stat-label">Max Record Gold</span><span class="daemon-stat-val" id="stat-gold">0</span></div>
                            <div class="daemon-stat-card"><span class="daemon-stat-label">Total Playtime (Mins)</span><span class="daemon-stat-val" id="stat-time">0</span></div>
                        </div>
                    </div>

                    <div id="tab-lead" style="display: none;">
                        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 15px; background: rgba(243, 179, 42, 0.1); padding: 10px 15px; border-radius: 6px; border: 1px solid rgba(243, 179, 42, 0.3);">
                            <div style="display: flex; flex-direction: column;">
                                <span style="color: ${accentYellow}; font-weight: 900; font-size: 18px; letter-spacing: 1px;">SEASON 0</span>
                                <span style="font-size: 10px; color: #aaa;">Top 50 Players (Resets End of Season)</span>
                            </div>
                            <div style="text-align: right;">
                                <span style="font-size: 10px; color: ${textMuted}; font-weight: bold;">SEASON ENDS IN</span><br>
                                <span id="season-timer" style="color: #fff; font-size: 16px; font-weight: bold; letter-spacing: 2px;">00d 00h 00m 00s</span>
                            </div>
                        </div>

                        <div style="display: flex; gap: 10px; margin-bottom: 15px;">
                            <button class="daemon-filter-btn active" data-sort="kills">TOP KILLS</button>
