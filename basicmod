            foundCount++; // Element tapıldı

            if (!el.dataset.listenerAdded) {
                const saved = cloadState(id);
                el.checked = saved;
                ccheckActions[id](el);

                if (id === "car006" && el.checked) {
                    const bArmor = document.getElementById("car001");
                    const dArmor = document.getElementById("car002");
                    if (bArmor) bArmor.disabled = true;
                    if (dArmor) dArmor.disabled = true;
                }

                el.addEventListener("change", () => {
                    ccheckActions[id](el);
                    if (id !== "combat_placement_auto_grind") {
                        csaveState(id, el.checked);
                    }
                });

                el.dataset.listenerAdded = "true";
            }
        }
    }

    cAttempts++;

    // Əgər HTML-də ən azı 1 dənə check tapıb işlətdiksə, dərhal "Uğurlu" yaz!
    if (foundCount > 0 && !successLogged) {
        if (typeof addToLog === "function") {
            addToLog("", "[System] Checks loaded successfully", "system");
        }
        successLogged = true; // Uğurlu mesajı artıq getdi
    }

    // Əgər siyahıdakı BÜTÜN elementlər tapılıbsa
    if (foundCount === ccheckIDs.length) {
        clearInterval(cwatcher);
    }
    // Vaxt bitdisə (Bəzi elementlər HTML-də yoxdursa)
    else if (cAttempts >= cMaxAttempts) {
        // Əgər ümumiyyətlə heç nə tapılmamışdısa (tam sıfır), o zaman Failed ver
        if (!successLogged && typeof addToLog === "function") {
            addToLog("", "[System] Failed to load checks", "system");
        }
        clearInterval(cwatcher); // Arxa plan axtarışını dayandır
    }
}, 300);

