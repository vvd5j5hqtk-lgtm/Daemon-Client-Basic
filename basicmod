    window.togglePassword = function(inputId, btn) {
        let input = document.getElementById(inputId);
        if (input.type === "password") { input.type = "text"; btn.innerText = "🔒︎"; btn.style.color = "#555"; }
        else { input.type = "password"; btn.innerText = "👁"; btn.style.color = "#555"; }
    };
    document.getElementById('tab-login-btn').onclick = function() {
        this.classList.add('active'); document.getElementById('tab-signup-btn').classList.remove('active');
        document.getElementById('daemon-login-form').style.display = 'flex'; document.getElementById('daemon-signup-form').style.display = 'none';
    };
    document.getElementById('tab-signup-btn').onclick = function() {
        this.classList.add('active'); document.getElementById('tab-login-btn').classList.remove('active');
        document.getElementById('daemon-signup-form').style.display = 'flex'; document.getElementById('daemon-login-form').style.display = 'none';
    };
    // 2. FIREBASE YÜKLƏNMƏSİ VƏ MƏNTİQ (DB / AUTH)
    const loadFirebaseScript = (url) => {
        return new Promise((resolve, reject) => {
            let script = document.createElement('script'); script.src = url; script.onload = resolve; script.onerror = reject; document.head.appendChild(script);
        });
    };
    try {
      //  console.log("Daemon: Firebase yüklənir...");
        await loadFirebaseScript("https://www.gstatic.com/firebasejs/8.10.1/firebase-app.js");
        await Promise.all([
            loadFirebaseScript("https://www.gstatic.com/firebasejs/8.10.1/firebase-auth.js"),
            loadFirebaseScript("https://www.gstatic.com/firebasejs/8.10.1/firebase-database.js")
        ]);
     //   console.log("Daemon: Firebase uğurla yükləndi!");
        // DİQQƏT: BURAYA ÖZ FIREBASE MƏLUMATLARINIZI YAZIN
        const firebaseConfig = {
            apiKey: "AIzaSyC19rL5TYeeFi6YPtdCCzFJRwKiLasY57M",
            authDomain: "daemonclient-e9e20.firebaseapp.com",
            projectId: "daemonclient-e9e20",
            storageBucket: "daemonclient-e9e20.firebasestorage.app",
            messagingSenderId: "190597725601",
            appId: "1:190597725601:web:e263a8fcf6c61b3fb69fe0"
        };
        if (!firebase.apps.length) { firebase.initializeApp(firebaseConfig); }
        const auth = firebase.auth();
        const db = firebase.database();
        const getFakeEmail = (username) => `${username.toLowerCase()}@daemon.mod`;
        let signupBtn = document.getElementById('signup-submit-btn');
        if(signupBtn) {
            signupBtn.onclick = function() {
                let username = document.getElementById('signup-username').value.trim();
                let pass = document.getElementById('signup-password').value;
                let conf = document.getElementById('signup-confirm').value;
                let remember = document.getElementById('signup-remember').checked;

                if (username.length < 3) return alert("Nickname must be at least 3 letters!");
                if (pass.length < 8) return alert("Password must be at least 8 characters long!");
                if (pass !== conf) return alert("The passwords are not the same!");

                let email = getFakeEmail(username);
                this.innerText = "CREATING...";
                this.disabled = true;

                auth.createUserWithEmailAndPassword(email, pass)
                    .then((userCredential) => {
                        let user = userCredential.user;
                        return db.ref('users/' + user.uid).set({
                            nickname: username,
                            createdAt: firebase.database.ServerValue.TIMESTAMP,
                            stats: { kills: 0, deaths: 0, highestStreak: 0, playtime: 0, maxGold: 0 }
                        });
                    })
                    .then(() => {
                        alert("Account created successfully! Welcome to Daemon.");
                        if(remember) localStorage.setItem('daemon_user_remember', 'true');
                        document.getElementById('daemon-auth-overlay').style.display = 'none';
                    })
                    .catch((error) => {
                        if (error.code === 'auth/email-already-in-use') alert("A user with this name already exists! Choose another name.");
                        else alert("An error occurred: " + error.message);
                        this.innerText = "CREATE ACCOUNT";
                        this.disabled = false;
                    });
            };
        }
        // --- GİRİŞ (LOGIN) MƏNTİQİ ---
        let loginBtn = document.getElementById('login-submit-btn');
        if(loginBtn) {
            loginBtn.onclick = function() {
                let username = document.getElementById('login-username').value.trim();
                let pass = document.getElementById('login-password').value;
                let remember = document.getElementById('login-remember').checked;

                if (username.length < 3 || pass.length < 8) return alert("The name or password is incorrect!");

                let email = getFakeEmail(username);
                this.innerText = "VERIFYING...";
                this.disabled = true;

                auth.signInWithEmailAndPassword(email, pass)
                    .then((userCredential) => {
                      //  alert("Uğurla daxil oldunuz!");
                        if(remember) localStorage.setItem('daemon_user_remember', 'true');
                        else localStorage.removeItem('daemon_user_remember');

                        document.getElementById('daemon-auth-overlay').style.display = 'none';
                    })
                    .catch((error) => {
                        alert("Login failed! Username or password is incorrect.");
                        this.innerText = "LOGIN";
                        this.disabled = false;
                    });
            };
        }
        // --- AVTOMATİK GİRİŞ (STAY LOGGED IN YOXLANMASI) ---
        auth.onAuthStateChanged((user) => {
            let shouldRemember = localStorage.getItem('daemon_user_remember') === 'true';
            if (user && shouldRemember) {
               // console.log("Daemon: Sistemə avtomatik daxil olundu:", user.uid);
                let overlay = document.getElementById('daemon-auth-overlay');
                if(overlay) overlay.style.display = 'none';
            } else if (user && !shouldRemember) {
                auth.signOut();
            }
        });

    } catch (error) {
        console.error("Daemon: Firebase yüklənə bilmədi.", error);
    }
})();

