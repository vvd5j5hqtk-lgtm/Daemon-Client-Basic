/* Düymənin kənarına daşmaması üçün əsas ayarlar (Bunu öz düymə klassınıza tətbiq edin) */
.ripple-btn {
    position: relative;
    overflow: hidden;
    /* Digər dizayn kodlarınız (padding, background və s.) bura gələcək */
}

/* Dalğa effektinin özü */
.ripple {
    position: absolute;
    border-radius: 50%;
    transform: scale(0);
    animation: ripple-anim 0.6s ease-out forwards;
    background: rgba(255, 255, 255, 0.25); /* Dalğanın rəngi və şəffaflığı */
    pointer-events: none;
}

@keyframes ripple-anim {
    to {
        transform: scale(4);
        opacity: 0;
    }
}

/* Sətir və qrup nizamı */
.dist-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
