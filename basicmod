    // Scroll mövqeyini yadda saxlamaq üçün dəyişənlər
    const menuContainer = document.getElementById("menucontainer");
    let currentTab = "home"; // İlk açılan tab "home" qəbul edirik
    let scrollPositions = {};

    buttons.forEach(btn => {
