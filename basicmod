                                <button class="daemon-btn" id="btn-logout" style="width: 100%; background: rgba(219, 110, 110, 0.05); border: 1px solid rgba(219, 110, 110, 0.2); color: #db6e6e; padding: 15px; font-size: 15px; margin-top: 5px; transition: 0.2s;">🚪 LOG OUT</button>

                            </div>
