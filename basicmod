let prevKillCount = 0;
let currentLifeStreak = 0;

function initAutoGG() {
    const killCounter = document.getElementById("killCounter");
    const chatInput = document.getElementById("killchats01");

    if (!killCounter || !chatInput) {
        setTimeout(initAutoGG, 500);
        return;
    }

    const savedKillChat = localStorage.getItem("savedKillChat01");
    if (savedKillChat !== null) {
        chatInput.value = savedKillChat;
    }
    chatInput.addEventListener("input", function() {
        localStorage.setItem("savedKillChat01", chatInput.value);
    });

    const observer = new MutationObserver(() => {
        const count = parseInt(killCounter.innerText, 10) || 0;

        // Rəqəm kiçilibsə (yəni ölüb yenidən doğulmusansa) 0-dan başla
        if (count < prevKillCount) {
            prevKillCount = count;
        }

        // Kimsə öldürüldüsə
        if (count > prevKillCount) {
            let difference = count - prevKillCount;
            prevKillCount = count;

            currentLifeStreak += difference; // Cari həyatdakı rekordu artır

            // FIREBASE KILLS & STREAK YENİLƏMƏSİ
            if (window.firebase && firebase.auth().currentUser) {
                let uid = firebase.auth().currentUser.uid;
                let userRef = firebase.database().ref('users/' + uid + '/stats');

                userRef.once('value').then((snapshot) => {
                    let stats = snapshot.val() || { kills: 0, highestStreak: 0 };
                    let newTotalKills = (stats.kills || 0) + difference;
                    let newHighestStreak = Math.max((stats.highestStreak || 0), currentLifeStreak);

                    userRef.update({
                        kills: newTotalKills,
                        highestStreak: newHighestStreak
                    });
                });
            }

            if (typeof window.daemonAddKill === "function") {
                for (let i = 0; i < difference; i++) {
                    window.daemonAddKill();
                }
            }

            if (typeof misctoggle !== 'undefined' && misctoggle.kill_chat) {
                const chat01 = chatInput.value;
                if (typeof sendChat === 'function') sendChat(chat01);
            }
        }
    });

    observer.observe(killCounter, { childList: true, characterData: true, subtree: true });
}

