function updateFollowChecks(activeId) {
    const followIds = ["bot_follow", "bot_mousefollow", "bot_circlefollow"];

    followIds.forEach(id => {
        if (id !== activeId) {
            const el = document.getElementById(id);
            if (el && el.checked) {
                el.checked = false;
                // Botun daxili toggle-nı söndürürük
                ccheckActions[id](el);
                // LocalStorage-ə yazırıq
                csaveState(id, false);
            }
        }
    });

    // Əgər circle rotation açıqdırsa və biz follow you və ya follow cursor açırıqsa, onu da söndürək
    if (activeId === "bot_follow" || activeId === "bot_mousefollow") {
        const rotEl = document.getElementById("bot_circlerotation");
        if (rotEl && rotEl.checked) {
            rotEl.checked = false;
            ccheckActions["bot_circlerotation"](rotEl);
            csaveState("bot_circlerotation", false);
        }
    }
}
