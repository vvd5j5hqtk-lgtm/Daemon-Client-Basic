                            <button class="daemon-filter-btn" data-sort="gold">TOP MAX GOLD</button>
                        </div>

                        <div class="daemon-lead-header">
                            <span style="width: 10%; text-align: center;">Rank</span>
                            <span style="width: 40%;">Player Name</span>
                            <span style="width: 15%; text-align: center;">K/D</span>
                            <span style="width: 15%; text-align: right;">Max Gold</span>
