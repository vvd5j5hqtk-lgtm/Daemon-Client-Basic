function addToLog(name, message, category = "system") {
    let logContent = document.getElementById('chat-log-content');
    if (!logContent) return;

    let now = new Date();
    let timeString = now.toLocaleTimeString('en-GB', { hour12: false });

    let msgElement = document.createElement('div');
    msgElement.className = `log-message log-msg-${category}`;

    let fullMessage = "";

    if (category === "chats") {
        fullMessage = name ? `<span style="color: #fff;">${name}:</span> ${message}` : message;
    }
    else if (category === "system") {
        fullMessage = name ? `${name} ${message}` : message;
    }
    else {
        let capCategory = category.charAt(0).toUpperCase() + category.slice(1);
        fullMessage = `<span style="font-weight: 900; opacity: 0.8;">[${capCategory}]</span> ${name ? name + " " : ""}${message}`;
    }

    msgElement.innerHTML = `
        <span class="log-time">${timeString}</span>
        <span class="log-text">${fullMessage}</span>
    `;

    logContent.appendChild(msgElement);
    logContent.scrollTop = logContent.scrollHeight;

    if (logContent.childNodes.length > 50) {
        logContent.removeChild(logContent.firstChild);
    }
}

