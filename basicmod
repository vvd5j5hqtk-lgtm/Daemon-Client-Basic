function renderPlayer(obj, ctxt) {
    ctxt = ctxt || mainContext;

    // 1. Koordinatları və Yumşaltma (Lerp) dəyişənlərini hazırlayırıq
    if (obj.lastX === undefined) {
        obj.lastX = obj.x;
        obj.lastY = obj.y;
        obj.smoothDiffX = 0;
        obj.smoothDiffY = 0;
    }

    let currentDiffX = obj.x - obj.lastX;
    let currentDiffY = obj.y - obj.lastY;

    // LERP (Yumşaltma) Məntiqi
    obj.smoothDiffX = (obj.smoothDiffX * 0.85) + (currentDiffX * 0.15);
    obj.smoothDiffY = (obj.smoothDiffY * 0.85) + (currentDiffY * 0.15);

    let tmpDir = !configs.showDir && !useWasd && obj == player
                ? configs.attackDir ? getVisualDir() : getSafeDir()
                : obj.dir || 0;
    let totalRot = tmpDir + (obj.dirPlus || 0);
    let shouldShowShadow = misctoggle.prediction_ghost;

    let isMoving = Math.abs(obj.smoothDiffX) > 0.05 || Math.abs(obj.smoothDiffY) > 0.05;
    let renderCount = (obj == player && shouldShowShadow && isMoving) ? 2 : 1;

    for (let i = 0; i < renderCount; i++) {
        ctxt.save();

        let isGhost = (renderCount === 2 && i === 0);

        if (isGhost) {
            // -- YENİLƏNMİŞ GHOST COLLISION (SLIDING) MƏNTİQİ --

            let maxPredDistance = 50;
            let stepSize = 5;

            let finalPredX = 0;
            let finalPredY = 0;

            let velLen = Math.sqrt(obj.smoothDiffX * obj.smoothDiffX + obj.smoothDiffY * obj.smoothDiffY);

            if (velLen > 0) {
                let dirX = obj.smoothDiffX / velLen;
                let dirY = obj.smoothDiffY / velLen;

                // Xəyali xarakterin mütləq koordinatlarını izləyirik
                let ghostX = obj.x;
                let ghostY = obj.y;
                let totalSteps = maxPredDistance * velLen;

                for (let dist = 0; dist <= totalSteps; dist += stepSize) {
                    // Hər addımda ghost-u irəli aparırıq
                    ghostX += dirX * stepSize;
                    ghostY += dirY * stepSize;

                    // Obyektlərlə toqquşmanı yoxlayırıq və kənara itələyirik (Slide effekti)
                    if (typeof gameObjects !== 'undefined') {
                        for (let j = 0; j < gameObjects.length; j++) {
                            let go = gameObjects[j];
                            if (!go || !go.active) continue;

                            let dx = ghostX - go.x;
                            let dy = ghostY - go.y;
                            let distToObject = Math.hypot(dx, dy);

                            let hitRadius = (obj.scale || 35) + (go.scale || 35);
                            let tolerance = 2; // Daha axıcı sürüşmə üçün toleransı azaltdıq

                            if (distToObject < (hitRadius - tolerance)) {
                                // Mərkəzlər eyni nöqtəyə düşərsə (nadir hal), sıfıra bölünmənin qarşısını alırıq
                                if (distToObject === 0) {
                                    dx = 1; dy = 0; distToObject = 1;
                                }

                                // Nə qədər iç-içə girdiklərini tapırıq
                                let overlap = (hitRadius - tolerance) - distToObject;

                                // Ghost-u obyektin mərkəzindən çölə doğru itələyirik
                                ghostX += (dx / distToObject) * overlap;
                                ghostY += (dy / distToObject) * overlap;
                            }
                        }
                    }
                }

                // Mütləq koordinatdan real koordinatı çıxıb render üçün lazımi offseti alırıq
                finalPredX = ghostX - obj.x;
                finalPredY = ghostY - obj.y;
            }

            ctxt.rotate(-totalRot);
            ctxt.translate(finalPredX, finalPredY);
            ctxt.rotate(totalRot);

            ctxt.globalAlpha = 0.4;
            // ----------------------------------------------
        } else {
            ctxt.globalAlpha = 1;
        }

        ctxt.lineWidth = outlineWidth;
        ctxt.lineJoin = "miter";
        let handAngle = Math.PI / 4 * (items.weapons[obj.weaponIndex].armS || 1);
        let oHandAngle = obj.buildIndex < 0 ? items.weapons[obj.weaponIndex].hndS || 1 : 1;
        let oHandDist = obj.buildIndex < 0 ? items.weapons[obj.weaponIndex].hndD || 1 : 1;
        let katanaMusket = obj == player && obj.weapons[0] == 3 && obj.weapons[1] == 15;

        // Quyruq
        if (obj.tailIndex > 0) {
            renderTailTextureImage(obj.tailIndex, ctxt, obj);
        }

        // Əldəki silah (Aşağı lay)
        if (obj.buildIndex < 0 && !items.weapons[obj.weaponIndex].aboveHand) {
            renderTool(items.weapons[katanaMusket ? 4 : obj.weaponIndex], config.weaponVariants[obj.weaponVariant].src, obj.scale, 0, ctxt);
            if (items.weapons[obj.weaponIndex].projectile != undefined && !items.weapons[obj.weaponIndex].hideProjectile) {
                renderProjectile(obj.scale, 0, items.projectiles[items.weapons[obj.weaponIndex].projectile], mainContext);
            }
        }

        ctxt.fillStyle = config.skinColors[obj.skinColor];
        // Əllər
        renderCircle(obj.scale * Math.cos(handAngle), obj.scale * Math.sin(handAngle), 14);
        renderCircle(obj.scale * oHandDist * Math.cos(-handAngle * oHandAngle), obj.scale * oHandDist * Math.sin(-handAngle * oHandAngle), 14);

        // Əldəki silah (Yuxarı lay)
        if (obj.buildIndex < 0 && items.weapons[obj.weaponIndex].aboveHand) {
            renderTool(items.weapons[obj.weaponIndex], config.weaponVariants[obj.weaponVariant].src, obj.scale, 0, ctxt);
            if (items.weapons[obj.weaponIndex].projectile != undefined && !items.weapons[obj.weaponIndex].hideProjectile) {
                renderProjectile(obj.scale, 0, items.projectiles[items.weapons[obj.weaponIndex].projectile], mainContext);
            }
        }

        // Əşya (Build) tutubsa
        if (obj.buildIndex >= 0) {
            var tmpSprite = getItemSprite(items.list[obj.buildIndex]);
            ctxt.drawImage(tmpSprite, obj.scale - items.list[obj.buildIndex].holdOffset, -tmpSprite.width / 2);
        }

        // --- XARAKTERİN BƏDƏNİ ---
        renderCircle(0, 0, obj.scale, ctxt);

        // --- YENİ ƏLAVƏ: KÜRƏKDƏKİ İKİNCİ SİLAH ---

        if (!isGhost && obj.weapons && obj.weapons.length > 1 && misctoggle.backpack) {
            let secWeapon;
            let secVariant = 0;

            if (obj.weaponIndex === obj.weapons[0]) {
                secWeapon = obj.weapons[1];
                secVariant = obj.secondaryVariant !== undefined ? obj.secondaryVariant : 0;
            } else {
                secWeapon = obj.weapons[0];
                secVariant = obj.primaryVariant !== undefined ? obj.primaryVariant : 0;
            }

            if (secWeapon !== undefined) {
                ctxt.save();
                ctxt.globalAlpha = 0.5;
                ctxt.rotate(Math.PI * 0.75);
                ctxt.translate(obj.scale * 0.1, 0);

                let variantSrc = config.weaponVariants[secVariant] ? config.weaponVariants[secVariant].src : config.weaponVariants[0].src;
                renderTool(items.weapons[secWeapon], variantSrc, obj.scale, 0, ctxt);
                ctxt.restore();
            }
        }

        if (obj.skinIndex > 0) {
            ctxt.rotate(Math.PI / 2);
            renderTextureSkin(obj.skinIndex, ctxt, null, obj);
        }

        ctxt.restore();
    }

    obj.lastX = obj.x;
    obj.lastY = obj.y;
}

