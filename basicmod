                let tmpRange;
                let berries = 4;
                let rotVal = (Math.PI * 2) / berries;
                for (let i = 0; i < berries; ++i) {
                    tmpRange = UTILS.randInt(obj.scale/3.5, obj.scale/2.3);
                    renderCircle(tmpRange * Math.cos(rotVal * i), tmpRange * Math.sin(rotVal * i),
                                 UTILS.randInt(10, 12), tmpContext);
                }
            }
        }
        // 2: Daş (Stone), 3: Qızıl (Gold)
        else if (obj.type == 2 || obj.type == 3) {
            tmpContext.fillStyle = (obj.type == 2) ? (biomeID == 2 ? "#938d77" : "#939393") : "#e0c655";
            renderStar(tmpContext, 3, obj.scale, obj.scale);
            tmpContext.fill();
            tmpContext.stroke();

            tmpContext.shadowBlur = null;
            tmpContext.shadowColor = null;

            tmpContext.fillStyle = (obj.type == 2) ? (biomeID == 2 ? "#b2ab90" : "#bcbcbc") : "#ebdca3";
            renderStar(tmpContext, 3, obj.scale * 0.55, obj.scale * 0.65);
            tmpContext.fill();
        }
        // 4: VULKAN (YENİ ƏLAVƏ)
        else if (obj.type == 4) {
            // Şəkildəki kimi kəskin səkkizbucaqlı (octagon) çəkmək üçün daxili funksiya
            function renderOctagon(ctx, radius) {
                ctx.beginPath();
                for (let i = 0; i < 8; i++) {
                    // Düz dayanması üçün bucağı 22.5 dərəcə (Math.PI / 8) fırladırıq
                    let angle = (i * Math.PI / 4) + (Math.PI / 8);
                    let x = radius * Math.cos(angle);
                    let y = radius * Math.sin(angle);
                    if (i === 0) ctx.moveTo(x, y);
                    else ctx.lineTo(x, y);
                }
                ctx.closePath();
            }

            // 1. Xarici daş hissəsi (Bozumtul-Mavi)
            tmpContext.fillStyle = "#505770";
            renderOctagon(tmpContext, obj.scale);
            tmpContext.fill();
            tmpContext.stroke(); // Orijinal qalın qara çərçivə

            tmpContext.shadowBlur = null;
            tmpContext.shadowColor = null;

            // 2. Daxili Lava hissəsi (Tünd Qırmızı)
            tmpContext.fillStyle = "#b83a27";
            renderOctagon(tmpContext, obj.scale * 0.55); // Lavanın ölçüsü (daşın təxminən yarısı)
            tmpContext.fill();

            // Lavanın ətrafındakı o yüngül tündləşmə (haşiyə)
            tmpContext.lineWidth = outlineWidth * 0.7;
            tmpContext.strokeStyle = "#9e3221"; // Daha tünd qırmızı çərçivə
            tmpContext.stroke();
        }

        tmpSprite = tmpCanvas;
        gameObjectSprites[tmpIndex] = tmpSprite;
    }
    return tmpSprite;
}
