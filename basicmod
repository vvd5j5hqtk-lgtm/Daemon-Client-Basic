                        </div>

                        <div id="daemon-leaderboard-list">
                            <div style="text-align:center; padding: 20px; color: ${textMuted};">Loading leaderboard...</div>
                        </div>
                    </div>

                </div>
            `;
            document.body.appendChild(profileModal);

            // --- SEASON TIMER MƏNTİQİ ---
            function getNextSundayNoon() {
                let now = new Date();
                let daysUntilSunday = 7 - now.getDay();
                if (daysUntilSunday === 7) daysUntilSunday = 0;
                let nextSunday = new Date(now.getFullYear(), now.getMonth(), now.getDate() + daysUntilSunday, 12, 0, 0);
                if (now.getTime() > nextSunday.getTime()) nextSunday.setDate(nextSunday.getDate() + 7);
                return nextSunday.getTime();
            }

            const targetDate = getNextSundayNoon();
            setInterval(() => {
                let now = new Date().getTime();
                let distance = targetDate - now;
                if (distance < 0) { document.getElementById("season-timer").innerHTML = "SEASON ENDED"; return; }
                let d = Math.floor(distance / (1000 * 60 * 60 * 24));
                let h = Math.floor((distance % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
                let m = Math.floor((distance % (1000 * 60 * 60)) / (1000 * 60));
                let s = Math.floor((distance % (1000 * 60)) / 1000);
                document.getElementById("season-timer").innerHTML = `${d}d ${h < 10 ? '0'+h : h}h ${m < 10 ? '0'+m : m}m ${s < 10 ? '0'+s : s}s`;
            }, 1000);

            // --- UI DÜYMƏ İDARƏETMƏLƏRİ ---
            let closeBtn = document.getElementById('close-profile-btn');
            closeBtn.onclick = () => { profileModal.style.display = "none"; };
            closeBtn.onmouseover = () => { closeBtn.style.color = "#fff"; };
            closeBtn.onmouseout = () => { closeBtn.style.color = textMuted; };

            let tabs = profileModal.querySelectorAll('.daemon-tab');
            tabs.forEach(tab => {
                tab.onclick = function() {
                    tabs.forEach(t => t.classList.remove('active'));
                    profileModal.querySelectorAll('div[id^="tab-"]').forEach(content => content.style.display = 'none');
                    this.classList.add('active');
                    document.getElementById(this.getAttribute('data-target')).style.display = 'block';
                };
            });

            // --- DRAG & DROP AVATAR MƏNTİQİ ---
            let currentBase64Avatar = "";
            const dropZone = document.getElementById('avatar-drop-zone');
            const fileInput = document.getElementById('hidden-file-input');
            const dropZoneText = document.getElementById('drop-zone-text');

            dropZone.onclick = () => fileInput.click();
            fileInput.onchange = (e) => handleFiles(e.target.files);

            dropZone.ondragover = (e) => { e.preventDefault(); dropZone.classList.add('dragover'); };
            dropZone.ondragleave = (e) => { e.preventDefault(); dropZone.classList.remove('dragover'); };
            dropZone.ondrop = (e) => { e.preventDefault(); dropZone.classList.remove('dragover'); handleFiles(e.dataTransfer.files); };

            function handleFiles(files) {
                if (files.length === 0) return;
                let file = files[0];
                if (!file.type.startsWith('image/')) return alert("Please select a valid image file!");

                let reader = new FileReader();
                reader.onload = function(e) {
                    let img = new Image();
                    img.onload = function() {
                        let canvas = document.createElement('canvas');
                        let ctx = canvas.getContext('2d');
                        canvas.width = 150;
                        canvas.height = 150;

                        let scale = Math.max(canvas.width / img.width, canvas.height / img.height);
                        let x = (canvas.width / 2) - (img.width / 2) * scale;
                        let y = (canvas.height / 2) - (img.height / 2) * scale;
                        ctx.drawImage(img, x, y, img.width * scale, img.height * scale);

                        currentBase64Avatar = canvas.toDataURL('image/jpeg', 0.8);
                        dropZone.innerHTML = `
                            <img src="${currentBase64Avatar}" style="width: 50px; height: 50px; border-radius: 50%; border: 2px solid ${accentYellow}; margin-bottom: 5px; object-fit: cover;">
                            <span style="color: ${accentYellow}; font-weight: bold;">Image Ready to Save</span>
                        `;
                    }
                    img.src = e.target.result;
                }
                reader.readAsDataURL(file);
            }

            // --- AD/AVATAR DƏYİŞDİRMƏ PANELİ ---
            const btnOpenName = document.getElementById('btn-open-name-edit');
            const btnOpenAvatar = document.getElementById('btn-open-avatar-edit');
            const sectionGeneral = document.getElementById('edit-general-section');
            const btnCancelGeneral = document.getElementById('btn-cancel-general');
            const btnSaveGeneral = document.getElementById('btn-save-general');

            btnOpenName.onclick = () => { sectionGeneral.style.display = 'flex'; };
            btnOpenAvatar.onclick = () => { sectionGeneral.style.display = 'flex'; };

            btnCancelGeneral.onclick = () => {
                sectionGeneral.style.display = 'none';
                document.getElementById('input-new-name').value = '';
                document.getElementById('input-general-pass').value = '';
                currentBase64Avatar = "";
                dropZone.innerHTML = `<span style="font-size: 20px;">📁</span><span>Click or Drag & Drop Image Here<br><small style="color:#666;">(Max 5MB. Auto-resized to 150x150)</small></span>`;
            };

            btnSaveGeneral.onclick = () => {
                let nName = document.getElementById('input-new-name').value.trim();
                let pass = document.getElementById('input-general-pass').value;

                if(pass.length < 1) return alert("Please enter your current password to save changes.");
                if(nName !== "" && nName.length < 3) return alert("Nickname must be at least 3 letters!");

                if(window.firebase && firebase.auth().currentUser) {
                    let user = firebase.auth().currentUser;
                    let cred = firebase.auth.EmailAuthProvider.credential(user.email, pass);

                    btnSaveGeneral.innerText = "SAVING...";

                    user.reauthenticateWithCredential(cred).then(() => {
                        let updates = {};
                        if(nName !== "") updates.nickname = nName;
                        if(currentBase64Avatar !== "") updates.avatar = currentBase64Avatar;

                        if(Object.keys(updates).length > 0) {
                            firebase.database().ref('users/' + user.uid).update(updates).then(() => {
                                btnCancelGeneral.click();
                                btnSaveGeneral.innerText = "SAVE CHANGES";
                            });
                        } else {
                            btnCancelGeneral.click();
                            btnSaveGeneral.innerText = "SAVE CHANGES";
                        }
                    }).catch((error) => {
                        alert("Incorrect password!");
                        btnSaveGeneral.innerText = "SAVE CHANGES";
                    });
                }
            };

            // --- PAROL DƏYİŞDİRMƏ PANELİ ---
            const btnOpenPass = document.getElementById('btn-open-pass-edit');
            const sectionPass = document.getElementById('edit-pass-section');
            const btnCancelPass = document.getElementById('btn-cancel-pass');
            const btnSavePass = document.getElementById('btn-save-pass');

            btnOpenPass.onclick = () => { sectionPass.style.display = 'flex'; btnOpenPass.style.display = 'none'; };
            btnCancelPass.onclick = () => {
                sectionPass.style.display = 'none';
                btnOpenPass.style.display = 'block';
                document.getElementById('input-old-pass').value = '';
                document.getElementById('input-new-pass').value = '';
                document.getElementById('input-conf-pass').value = '';
            };

            btnSavePass.onclick = () => {
                let oldP = document.getElementById('input-old-pass').value;
                let newP = document.getElementById('input-new-pass').value;
                let confP = document.getElementById('input-conf-pass').value;

                if(oldP.length < 1) return alert("Enter current password.");
                if(newP.length < 8) return alert("New password must be at least 8 characters.");
                if(newP !== confP) return alert("New passwords do not match.");

                if(window.firebase && firebase.auth().currentUser) {
                    let user = firebase.auth().currentUser;
                    let cred = firebase.auth.EmailAuthProvider.credential(user.email, oldP);

                    btnSavePass.innerText = "UPDATING...";

                    user.reauthenticateWithCredential(cred).then(() => {
                        user.updatePassword(newP).then(() => {
                            alert("Password updated successfully!");
                            btnCancelPass.click();
                            btnSavePass.innerText = "UPDATE PASSWORD";
                        }).catch(e => { alert(e.message); btnSavePass.innerText = "UPDATE PASSWORD"; });
                    }).catch(() => {
                        alert("Current password is incorrect!");
                        btnSavePass.innerText = "UPDATE PASSWORD";
                    });
                }
            };

            // --- LOG OUT MƏNTİQİ ---
            const btnLogout = document.getElementById('btn-logout');
            btnLogout.onmouseover = () => { btnLogout.style.background = "rgba(219, 110, 110, 0.15)"; btnLogout.style.borderColor = "#db6e6e"; };
            btnLogout.onmouseout = () => { btnLogout.style.background = "rgba(219, 110, 110, 0.05)"; btnLogout.style.borderColor = "rgba(219, 110, 110, 0.2)"; };
            btnLogout.onclick = () => {
                if(confirm("Are you sure you want to log out?")) {
                    if(window.firebase) {
                        firebase.auth().signOut().then(() => {
                            localStorage.removeItem('daemon_user_remember');
                            window.location.reload();
                        });
                    }
                }
            };
        }

        let profileBtn = document.getElementById('profile-btn');
        if (profileBtn) {
            profileBtn.onclick = (e) => {
                e.preventDefault();
                profileModal.style.display = (profileModal.style.display === "none" || profileModal.style.display === "") ? "flex" : "none";
            };
        }
    }

    let waitForBtn = setInterval(() => {
        if (document.getElementById('profile-btn')) {
            initProfileSystem();
            clearInterval(waitForBtn);

            // ========================================================
            // FIREBASE DATA FETCH (PROFILE & LEADERBOARD)
            // ========================================================
            if (window.firebase) {

                let currentSortMethod = "kills"; // Default filter
                let allPlayersData = []; // Bütün oyunçuları burada saxlayırıq ki, rahat sıralayaq

                // KD üçün xüsusi rəng funksiyası
                const getKdStyle = (kdValue) => {
                    let val = parseFloat(kdValue);
                    if (val >= 5.0) return "color: #ff4d4d; font-weight: 900; text-shadow: 0 0 10px rgba(255, 77, 77, 0.8);";
                    if (val >= 2.0) return "color: #4CAF50; font-weight: 900; text-shadow: 0 0 8px rgba(76, 175, 80, 0.5);";
                    if (val >= 1.0) return "color: #f3b32a; font-weight: bold;";
                    return "color: #666;";
                };

                // Liderboardu ekrana çəkən funksiya
                const renderLeaderboard = () => {
                    // Seçilən filterə görə siyahını sıralayırıq
                    allPlayersData.sort((a, b) => {
                        let aKills = a.stats?.kills || 0; let bKills = b.stats?.kills || 0;
                        let aDeaths = a.stats?.deaths || 0; let bDeaths = b.stats?.deaths || 0;
                        let aKd = aDeaths === 0 ? aKills : aKills / aDeaths;
                        let bKd = bDeaths === 0 ? bKills : bKills / bDeaths;
                        let aGold = a.stats?.maxGold || 0; let bGold = b.stats?.maxGold || 0;

                        if (currentSortMethod === "kills") return bKills - aKills;
                        if (currentSortMethod === "kd") return bKd - aKd;
                        if (currentSortMethod === "gold") return bGold - aGold;
                        return 0;
                    });

                    // Sadəcə top 50-ni alırıq
                    let top50 = allPlayersData.slice(0, 50);
                    let leadHTML = "";
                    let myName = document.getElementById('daemon-display-name').innerText;

                    top50.forEach((p, index) => {
                        let rank = index + 1;
                        let rankClass = rank === 1 ? "rank-1" : rank === 2 ? "rank-2" : rank === 3 ? "rank-3" : "";
                        let rankStyle = rank > 3 ? "color: #888;" : "";

                        let k = p.stats?.kills || 0;
                        let d = p.stats?.deaths || 0;
                        let kd = d === 0 ? k : (k / d).toFixed(2);
                        let gold = p.stats?.maxGold || 0;
                        let isMe = p.nickname === myName;
                        let rowBg = isMe ? "background: rgba(243, 179, 42, 0.1); border-color: rgba(243, 179, 42, 0.3);" : "";

                        let avatarSrc = (p.avatar && (p.avatar.startsWith('http') || p.avatar.startsWith('data:image'))) ? p.avatar : null;
                        let avatarHTML = avatarSrc
                            ? `<img src="${avatarSrc}" style="width: 24px; height: 24px; border-radius: 50%; object-fit: cover; border: 1px solid #444; flex-shrink: 0;">`
                            : `<div style="width: 24px; height: 24px; border-radius: 50%; background: #222; border: 1px solid #444; display: flex; align-items: center; justify-content: center; font-size: 12px; flex-shrink: 0;">👤</div>`;

                        let kdStyle = getKdStyle(kd);

                        // Hansı filter aktivdirsə, o sütunu parıldadırıq
                        let kStyle = currentSortMethod === "kills" ? "color: #f3b32a; font-weight: bold; font-size: 15px;" : "color: #fff;";
                        let goldStyle = currentSortMethod === "gold" ? "color: #f3b32a; font-weight: bold; font-size: 15px;" : "color: #f3b32a;";

                        leadHTML += `
                        <div class="daemon-lead-row" style="${rowBg}">
                            <span class="${rankClass}" style="width: 10%; text-align: center; ${rankStyle}">#${rank}</span>
                            <span style="width: 40%; font-weight: bold; color: ${isMe ? '#f3b32a' : '#fff'}; display: flex; align-items: center; gap: 8px; overflow: hidden; white-space: nowrap;">
                                ${avatarHTML}
                                <span style="text-overflow: ellipsis; overflow: hidden;">${p.nickname || "Unknown"}</span>
                            </span>
                            <span style="width: 15%; text-align: center; ${kdStyle} ${currentSortMethod === "kd" ? 'font-size: 15px;' : ''}">${kd}</span>
                            <span style="width: 15%; text-align: right; ${goldStyle}">${gold}</span>
                            <span style="width: 20%; text-align: right; ${kStyle}">${k}</span>
                        </div>
                        `;
                    });
                    document.getElementById('daemon-leaderboard-list').innerHTML = leadHTML;
                };

                // Filter düymələrinin idarəedilməsi
                document.querySelectorAll('.daemon-filter-btn').forEach(btn => {
                    btn.onclick = function() {
                        document.querySelectorAll('.daemon-filter-btn').forEach(b => b.classList.remove('active'));
                        this.classList.add('active');
                        currentSortMethod = this.getAttribute('data-sort');
                        renderLeaderboard(); // Təzədən sırala
                    };
                });


                firebase.auth().onAuthStateChanged((user) => {
                    if (user) {
                        // 1. Şəxsi Məlumatları Yüklə
                        firebase.database().ref('users/' + user.uid).on('value', (snapshot) => {
                            const data = snapshot.val();
                            if(data) {
                                document.getElementById('daemon-display-name').innerText = data.nickname || "Unknown";

                                let avatarImg = document.getElementById('daemon-avatar-img');
                                let avatarPlace = document.getElementById('daemon-avatar-placeholder');
                                if(data.avatar && (data.avatar.startsWith('http') || data.avatar.startsWith('data:image'))) {
                                    avatarImg.src = data.avatar;
                                    avatarImg.style.display = 'block';
                                    avatarPlace.style.display = 'none';
                                } else {
                                    avatarImg.style.display = 'none';
                                    avatarPlace.style.display = 'flex';
                                }

                                let k = data.stats?.kills || 0;
                                let d = data.stats?.deaths || 0;
                                let kd = d === 0 ? k : (k / d).toFixed(2);

                                document.getElementById('stat-kills').innerText = k;
                                document.getElementById('stat-deaths').innerText = d;

                                let statKdElement = document.getElementById('stat-kd');
                                statKdElement.innerText = kd;
                                statKdElement.style = getKdStyle(kd);

                                document.getElementById('stat-streak').innerText = data.stats?.highestStreak || 0;
                                document.getElementById('stat-gold').innerText = data.stats?.maxGold || 0;
                                document.getElementById('stat-time').innerText = data.stats?.playtime || 0;
                            }
                        });

                        // 2. Leaderboard Məlumatlarını Bazadan Al və Saxla
                        firebase.database().ref('users').on('value', (snapshot) => {
                            allPlayersData = [];
                            snapshot.forEach(child => {
                                allPlayersData.push(child.val());
                            });
                            renderLeaderboard(); // Məlumat gələn kimi ekrana çək
                        });
                    }
                });
            }
        }
    }, 500);
})();





// Auto Verfy Capcha
(function() {
    const WS = window.WebSocket;

    window.WebSocket = function(...args) {
        const socketInstance = new WS(...args);
        window['__ws_instance'] = socketInstance;

        socketInstance.addEventListener('message', (e) => {
            if (window['__handler']) {
                window['__handler'](e);
            }
        });
        return socketInstance;
    };
    window.WebSocket.prototype = WS.prototype;

    let attempts = 0;
    const maxAttempts = 15; // 15 saniyəlik axtarış limiti

    const autoClickAltcha = setInterval(() => {
        const altchaDiv = document.getElementById('altcha');
        const altchaCheckbox = document.getElementById('altcha_checkbox');

        if (altchaDiv && altchaCheckbox) {
            altchaDiv.style.display = 'none';
            altchaCheckbox.checked = true;
            altchaCheckbox.dispatchEvent(new MouseEvent('click'));

            // Uğurlu olduqda:
            if (typeof addToLog === "function") {
                addToLog("", "[System] Verified Capcha", "system");
            }

            clearInterval(autoClickAltcha);
        } else {
            attempts++;
            // 15 saniyə ərzində tapılmazsa və ya uğursuz olarsa:
            if (attempts >= maxAttempts) {
                if (typeof addToLog === "function") {
                    addToLog("", "[System] Failed to verify Captcha", "system");
                }
                clearInterval(autoClickAltcha);
            }
        }
    }, 1000);
})();
