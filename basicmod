// AUTOPUSH:
function autoPush() {
    const forceStop = () => {
        if (track.pushdata.autoPush) {
            packet("9", undefined, 1);
        }
        track.pushdata.autoPush = false;
        pathFind.active = false;
        pathFind.chaseNear = false;
        window.currentPushSpike = null;
        window.nextPushTarget = null; // Sıfırlama əlavə olundu
    };

    if (!near || !near.active) return forceStop();

    let myObjects = closeObjects.filter(tmp => tmp.active && tmp.isTeamObject(player));

    let currentTrap = myObjects.find(tmp => tmp.trap && UTILS.getDist(tmp, near, 0, 2) <= (near.scale + tmp.getScale() + 20));
    if (!currentTrap) return forceStop();

    let targetObject = null;
    let finalSpike = null; // Vizual üçün çölə çıxarıldı

    let immediateSpike = myObjects.find(tmp =>
        tmp.dmg && UTILS.getDist(tmp, currentTrap, 0, 0) <= (currentTrap.scale + tmp.scale + 25)
    );

    if (immediateSpike) {
        targetObject = immediateSpike;
        finalSpike = immediateSpike;
    } else if (combatattacktoggle.advanced_auto_push) {
        finalSpike = myObjects.filter(tmp => tmp.dmg && UTILS.getDist(tmp, currentTrap, 0, 0) < 450)
            .sort((a, b) => UTILS.getDist(a, currentTrap, 0, 0) - UTILS.getDist(b, currentTrap, 0, 0))[0];

        if (finalSpike) {
            let bridgeTrap = myObjects.filter(tmp =>
                tmp.trap && tmp.sid !== currentTrap.sid &&
                UTILS.getDist(tmp, currentTrap, 0, 0) < 180 &&
                UTILS.getDist(tmp, finalSpike, 0, 0) < UTILS.getDist(currentTrap, finalSpike, 0, 0)
            ).sort((a, b) => UTILS.getDist(a, currentTrap, 0, 0) - UTILS.getDist(b, currentTrap, 0, 0))[0];

            targetObject = bridgeTrap || finalSpike;
        }
    }

    if (!targetObject) return forceStop();

    window.currentPushSpike = targetObject;
    // --- VİZUAL ÜÇÜN ƏLAVƏ: Əgər hədəf tikan deyilsə, növbəti hədəf tikandır ---
    window.nextPushTarget = (finalSpike && targetObject.sid !== finalSpike.sid) ? finalSpike : null;

    let distToTarget = UTILS.getDist(near, targetObject, 2, 0);
    let isTouching = objectManager.checkCollision2(near, targetObject);

    if (isTouching && targetObject.dmg && distToTarget < (near.scale + targetObject.getScale() + 5)) {
        forceStop();
        return;
    }

    let angleToTarget = UTILS.getDirect(near, targetObject, 2, 0);
    let pos = {
        x: targetObject.x + (260 * Math.cos(angleToTarget)),
        y: targetObject.y + (260 * Math.sin(angleToTarget)),
        x2: targetObject.x + ((distToTarget + player.scale) * Math.cos(angleToTarget)),
        y2: targetObject.y + ((distToTarget + player.scale) * Math.sin(angleToTarget))
    };

    track.pushdata.autoPush = true;

    let pushAngle = Math.atan2(near.y2 - targetObject.y, near.x2 - targetObject.x);
    let point = {
        x: near.x2 + Math.cos(pushAngle) * 55,
        y: near.y2 + Math.sin(pushAngle) * 55,
    };

    if (distToTarget >= 100) {
        if (UTILS.lineInRect(player.x2 - 5, player.y2 - 5, player.x2 + 5, player.y2 + 5, near.x2, near.y2, pos.x, pos.y)) {
            packet("9", near.aim2, 1);
        } else {
            packet("9", UTILS.getDirect(pos, player, 2, 2), 1);
        }
    } else {
        packet("9", Math.atan2(point.y - player.y2, point.x - player.x2), 1);
    }
}

