function setupSelects() {
    // Bütün selector-ların ID siyahısını bir massivə yığırıq
    const selectIds = [
        'marks_type', 'health_type',
        'insta_type', 'tick_type', 'defencehat_type', 'defenceacc_type','autobreak_type',
        'biomehat_type','idlebiomehat_type','idlebiomeacc_type', 'biomeacc_type', "animalacc_type", "lefthithat_type" , "lefthitacc_type", "secondarygrind_type", "primarygrind_type",

        //clicks
'togameobjecthat_type',
'togameobjectacc_type',
'toobjectacc_type',
'toobjecthat_type',
'toanimalhat_type',
'toanimalacc_type',
'toenemiehat_type',
'toenemieacc_type',
    ];

    selectIds.forEach(id => {
        const element = document.getElementById(id);

        // Əgər element səhifədə yoxdursa, error verməsin deyə keçirik (Safety Check)
        if (!element) return;

        // 1. Yaddaşdan (localStorage) köhnə seçimi yoxla
        const savedChoice = localStorage.getItem(`${id}_choice`);
        if (savedChoice) {
            element.value = savedChoice;
        }

        // 2. Seçim dəyişəndə həm yaddaşa yazsın, həm də lazımi dəyişəni yeniləsin
        element.addEventListener('change', () => {
            localStorage.setItem(`${id}_choice`, element.value);
            console.log(`${id} dəyişdirildi: ${element.value}`);

            // Əgər oyunun içində hansısa funksiyanı dərhal çağırmaq lazımdırsa, bura yaz:
            // updateGameSettings(id, element.value);
        });
    });
}

