            playBtn.innerHTML = "PLAY";
            _set(playBtn, { width: "100%", padding: "16px", cursor: "pointer", border: "none", borderRadius: "8px", backgroundColor: "#444", color: "#fff", fontSize: "18px", fontWeight: "900", transition: "0.3s", marginBottom: "10px" });

