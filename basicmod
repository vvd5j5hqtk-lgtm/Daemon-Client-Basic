        let profileModal = document.getElementById('daemon-profile-modal');
        if (!profileModal) {
            profileModal = document.createElement('div');
            profileModal.id = "daemon-profile-modal";
            _set(profileModal, {
                display: "none", position: "fixed", top: "50%", left: "50%", transform: "translate(-50%, -50%)",
