                                    <div style="display: flex; flex-direction: column;">
                                        <span style="font-size: 11px; color: ${textMuted}; font-weight: bold; margin-bottom: 3px;">NICKNAME</span>
                                        <span id="daemon-display-name" style="font-size: 24px; font-weight: bold; color: ${accentYellow};">Loading...</span>
