            const text = document.getElementById(`txt-${id}`);
            const rem = document.getElementById(`rem-${id}`);

            if(!dz) return;

            dz.addEventListener('dragover', e => { e.preventDefault(); dz.style.borderColor = "#00e676"; });
            dz.addEventListener('dragleave', () => { dz.style.borderColor = "#666"; });
            dz.addEventListener('drop', e => {
                e.preventDefault();
                const file = e.dataTransfer.files[0];
                if (file && file.type.startsWith('image/')) {
                    const reader = new FileReader();
                    reader.onload = ev => {
                        userCustomTextures[id] = ev.target.result;
                        prev.src = ev.target.result;
                        prev.style.display = 'block';
                        text.style.display = 'none';
                        rem.style.display = 'flex';
                    };
                    reader.readAsDataURL(file);
                }
            });
            rem.onclick = (e) => {
                e.stopPropagation();
                delete userCustomTextures[id];
                prev.src = "";
                prev.style.display = 'none';
                text.style.display = 'block';
                rem.style.display = 'none';
            };
        });

        saveBtn.onclick = () => {
            localStorage.setItem('user_textures', JSON.stringify(userCustomTextures));
            window.location.reload();
        };

        resetBtn.onclick = () => {
            if(confirm("Sıfırlansın?")) {
                localStorage.removeItem('user_textures');
                window.location.reload();
            }
        };
    }

    // Sənin menyun yaranana qədər yoxlayır
    const checkExist = setInterval(() => {
        if (document.querySelector('.texture-scroll-container')) {
            initTextureSystem();
            clearInterval(checkExist);
        }
    }, 500);

