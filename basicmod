        if (showHealth && health !== undefined && health !== null) {
            textParts.push("HP:" + health);
        }
        if (showDist) {
            let step = 0.25;
            let smoothedDist = (Math.round(dist / step) * step).toFixed(2);
            textParts.push(smoothedDist);
        }
        let fullText = textParts.join(" ");
