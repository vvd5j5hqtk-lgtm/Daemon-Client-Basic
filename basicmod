            if (!obj.active || obj.isTeamObject(player)) return false;

            let dist = UTILS.getDist(obj, player, 0, 3);

            // 1. Tikan yoxlaması
            if (obj.dmg) {
                return dist <= (player.scale * 2 + obj.getScale() + 15);
            }

            // 2. Boost Pad yoxlaması
            if (obj.name === 'boost pad') {
                return dist <= (player.scale * 2.5 + obj.getScale() + 15);
            }

            return false;
        });

        if (dangerObj) {
            // Təhlükəli obyektin (tikanın və ya boost pad-in) bizə görə istiqaməti
            let dangerDir = UTILS.getDirect(dangerObj, player, 0, 2);

            // Getmək istədiyimiz istiqamət ilə təhlükənin istiqaməti arasındakı bucaq fərqi
            let diff = Math.abs(Math.atan2(Math.sin(intendedDir - dangerDir), Math.cos(intendedDir - dangerDir)));

            // Əgər bucaq fərqi 90 dərəcədən (Math.PI / 2) kiçikdirsə...
            if (diff < Math.PI / 2) {
                // Hərəkəti blokla! (Xarakter avtomatik dayanacaq)
                return undefined;
            }
        }
    }

    return intendedDir;
}
