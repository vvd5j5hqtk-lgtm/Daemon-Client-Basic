            if (!openMenuBtn.parentNode) setup.appendChild(openMenuBtn);

            // PROFIL DÜYMƏSİ (Pəncərəni açmaq üçün idarəetmə 2-ci koddadır)
            let profileBtn = _get('profile-btn') || document.createElement('button');
            profileBtn.id = "profile-btn"; profileBtn.innerText = "PROFILE";
            _set(profileBtn, { width: "100%", padding: "16px", cursor: "pointer", border: "none", borderRadius: "8px", backgroundColor: "#2a5c82", color: "#fff", fontSize: "18px", fontWeight: "900", transition: "0.3s" });
