        if (dynamicCircle) dynamicCircle.style.backgroundColor = mainColor;

        // Daemon Client yazısı
        if (daemonLogo) {
            daemonLogo.style.color = mainColor;
            daemonLogo.style.textShadow = `0 0 10px ${mainColor}`;
        }

        // MENU HEADER - Altına rəngli xətt və yüngül parıltı
        if (menuHeader) {
            menuHeader.style.borderBottom = `2px solid ${mainColor}`;
            menuHeader.style.boxShadow = `0 4px 15px -5px ${mainColor}`;
            menuHeader.style.transition = "all 0.2s ease";
        }

        boxes.forEach(box => {
            box.style.borderLeft = `5px solid ${mainColor}`;
            box.style.boxShadow = `inset 10px 0 15px -10px ${mainColor}`;
        });

        headers.forEach(h2 => {
            h2.style.textShadow = `0 0 10px ${mainColor}`;
        });
    }
}

