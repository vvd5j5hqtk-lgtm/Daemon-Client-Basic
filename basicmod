        mainContext.textBaseline = "middle";
        mainContext.strokeStyle = "#333333";
        mainContext.lineWidth = 3;
        mainContext.lineJoin = "round";
        mainContext.strokeText(fullText, textX, textY);
        mainContext.fillStyle = "#D3D3D3";
        mainContext.fillText(fullText, textX, textY);
    }
}

