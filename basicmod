            // Əgər closeObjects nədənsə işləməsə, traps.info-dakı bütün tikanları yoxla
            nearbySpikes = traps.info.slice(1);
        }

        // Əgər ətrafımızda 2 və ya daha çox tikan varsa, ikisini birdən vurmağı yoxlayırıq
        if (nearbySpikes.length >= 2) {
            // Ən yaxın 2 tikan
            const spike1 = nearbySpikes[0];
            const spike2 = nearbySpikes[1];
            const obj1Scale = spike1.scale || 50;
            const obj2Scale = spike2.scale || 50;

