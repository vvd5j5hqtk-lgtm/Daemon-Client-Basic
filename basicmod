document.querySelectorAll('.log-filter').forEach(btn => {
    let targetCategory = btn.getAttribute('data-target');
    let contentBox = document.getElementById('chat-log-content');

    // Yüklənərkən LocalStorage-dan yoxlayırıq (Varsayılan olaraq "true" qəbul edirik)
    let isSavedActive = localStorage.getItem(`chatFilter_${targetCategory}`);
    if (isSavedActive === "false") {
        btn.classList.remove('active');
        contentBox.classList.add(`hide-${targetCategory}`);
    }

    btn.addEventListener('click', (e) => {
        e.target.classList.toggle('active');
        let isActive = e.target.classList.contains('active');

        if (isActive) {
            contentBox.classList.remove(`hide-${targetCategory}`);
        } else {
            contentBox.classList.add(`hide-${targetCategory}`);
        }

        // Vəziyyəti LocalStorage-ə yazırıq
        localStorage.setItem(`chatFilter_${targetCategory}`, isActive);

        contentBox.scrollTop = contentBox.scrollHeight;
    });
});

