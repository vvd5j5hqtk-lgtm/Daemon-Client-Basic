function antiKnockBack(enemyPlayer) {
    if (!enemyPlayer || !enemyPlayer.active || traps.inTrap) return;

    // 1. DÜZGÜN BUCAQ TƏYİNİ: Client-dən asılı olaraq rəqibin baxdığı yönü tapırıq
    const enemyAim = enemyPlayer.aim !== undefined ? enemyPlayer.aim : (enemyPlayer.aim2 || enemyPlayer.dir || enemyPlayer.d || 0);

    // 2. MƏSAFƏ: Rəqib çox uzaqdırsa yoxlamağa ehtiyac yoxdur.
    // Məsafəni bir az bol (150) tuturuq ki, gecikmə (ping) olanda da işləsin.
    const distToEnemy = UTILS.getDist(player, enemyPlayer, 0, 0);
    if (distToEnemy > 150) return;

    const knockbackDistance = 85;

    // Rəqib vursa hara uçacağımızı hesablayırıq
    const endPosX = player.x + Math.cos(enemyAim) * knockbackDistance;
    const endPosY = player.y + Math.sin(enemyAim) * knockbackDistance;

    const dangerousSpikes = closeObjects.filter(obj => obj.active && obj.damage > 0 && !obj.isTeamObject(player));

    for (let spike of dangerousSpikes) {
        const distToSpikeAfterHit = Math.hypot(endPosX - spike.x, endPosY - spike.y);

        // +10 vahid ehtiyat payı qoyuruq ki, riskə girməyək
        if (distToSpikeAfterHit <= (spike.scale + (player.scale || 35) + 10)) {

            // 1. Təhlükə anında dərhal can basır
            if (player.shameCount < 4) place(0, getAttackDir());

            // 2. Qaçış bucağı: Tikandan tam əks tərəfə
            const escapeAngle = Math.atan2(player.y - spike.y, player.x - spike.x);

            // 3. ZƏMANƏTLİ HƏRƏKƏT SİSTEMİ:
            // Modunda hansı funksiya işləyirsə, onu hərəkətə gətiririk
            if (typeof setMoveDir === "function") {
                setMoveDir(escapeAngle);
            }

            // Əgər WASD basılıdırsa və setMoveDir işləmirsə, birbaşa oyunçu dəyişənini məcbur edirik
            if (typeof my !== 'undefined') {
                my.dir = escapeAngle;
            } else {
                player.moveDir = escapeAngle;
            }

            // Alternativ qorunma: Əgər qaçmaqla qurtula bilmiriksə, özümüzlə tikan arasına divar/tələ qoy
            // place(4, escapeAngle + Math.PI); // (İstəsən bunu da aça bilərsən, bloklamaq üçün)

            break;
        }
    }
