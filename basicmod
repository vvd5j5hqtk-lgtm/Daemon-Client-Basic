                my.reloaded = true;
                let fastSpeed = items.weapons[player.weapons[0]].spdMult < items.weapons[player.weapons[1]].spdMult ? 1 : 0;
                if (player.weaponIndex != player.weapons[fastSpeed] || player.buildIndex > -1) {
                    selectWeapon(player.weapons[fastSpeed]);
