}

/* --- ƏSAS DÜYMƏ (SÖNÜK VƏZİYYƏT) --- */
.dist-btn {
    width: 100px;
    height: 35px;
    background: #111; /* Qaranlıq, sönük fon */
    border: 1px solid #222; /* Tünd çərçivə */
    border-radius: 4px;
    cursor: pointer;
    position: relative;
    overflow: hidden; /* Ağ xəttin düymədən kənara çıxmaması üçün */
    transition: background 0.3s, color 0.3s, border-color 0.3s, box-shadow 0.3s;

    /* Sənin istədiyin yazı tərzi (Extra Bold, Inter, Smoothing) */
    font-family: 'Inter', sans-serif;
    font-weight: 800;
    font-size: 12px; /* Düyməyə uyğun ölçü */
    color: #88888d; /* Sönük vəziyyətdəki rəng */
    letter-spacing: -0.5px;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
}

/* --- YANILI (ENABLED) VƏZİYYƏT --- */
.dist-btn.enabled-btn {
    background: #222; /* Bir az işıqlı fon */
    border: 1px solid #555; /* Görünən çərçivə */
    color: #fff; /* Yandıqda tam ağ və kəskin oxunaqlı olsun */
    box-shadow: inset 0 0 8px rgba(255, 255, 255, 0.05); /* Yüngül içlik kölgəsi */
}
/* --- AĞ XƏTT (LAZER) ÜÇÜN BAZA --- */
.dist-btn::after {
    content: "";
    position: absolute;
    top: 0;
    width: 3px; /* Xəttin qalınlığı */
    height: 100%;
    background: #fff;
    box-shadow: 0 0 8px #fff, 0 0 15px #fff; /* Parlaq işıq effekti */
    opacity: 0; /* Normalda görünmür */
}

/* YANDIRANDA - Soldan sağa keçid */
.dist-btn.animating-on::after {
    animation: scanRight 0.35s ease-out forwards;
}

/* SÖNDÜRƏNDƏ - Sağdan sola keçid */
.dist-btn.animating-off::after {
    animation: scanLeft 0.35s ease-out forwards;
}

/* Animasiya Keyframe-ləri */
@keyframes scanRight {
    0% { left: -10px; opacity: 1; }
    50% { opacity: 1; }
    100% { left: 100%; opacity: 0; }
}
@keyframes scanLeft {
    0% { left: 100%; opacity: 1; }
    50% { opacity: 1; }
    100% { left: -10px; opacity: 0; }
}
