function getMoveDir() {
    let dx = 0;
    let dy = 0;

    // Klaviaturadan gələn hərəkəti oxuyuruq
    for (let [key, tmpDir] of Object.entries({
        [keybinds.movew]: [0, -1], // W
        [keybinds.moves]: [0, 1],  // S
        [keybinds.movea]: [-1, 0], // A
        [keybinds.moved]: [1, 0],  // D
    })) {
        dx += !!keys[key] * tmpDir[0];
        dy += !!keys[key] * tmpDir[1];
    }

    // Əgər heç bir düymə basılmayıbsa, undefined qaytarırıq (dayanır)
    if (dx == 0 && dy == 0) return undefined;

    // Getmək istədiyimiz əsas istiqaməti (radianla) hesablayırıq
    let intendedDir = Math.atan2(dy, dx);

    // --- SAFEWALK MƏNTİQİ: TƏHLÜKƏYƏ DOĞRU GETMƏYİ BLOKLAMAQ (Spike & Boost Pad) ---
    if (combatdefensetoggle.safewalkSTOP && !traps.inTrap) {

