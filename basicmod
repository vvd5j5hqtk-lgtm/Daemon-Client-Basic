        }

        // HƏDƏF 2: Əgər 2 tikana eyni anda vura bilmiriksə (çox aralıdırlar) və ya cəmi 1 tikan varsa:
        // YENƏ DƏ TƏLƏNİ BOŞ VER. Bütün gücünlə ancaq o 1 tikana (primarySpike) vur ki, səni ora itələməsinlər.
        bestAim = Math.atan2(primarySpike.y - player.y2, primarySpike.x - player.x2);

